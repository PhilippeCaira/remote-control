# ============================================================================
# remote-control — server environment
#
# Copy this file to `.env` on the VPS (never commit `.env`):
#   cp .env.example .env
#   chmod 600 .env
# Then edit every value marked <CHANGE_ME>.
# ============================================================================

# ---------------------------------------------------------------------------
# Timezone used by the rustdesk container (IANA name).
# ---------------------------------------------------------------------------
TZ=Europe/Brussels

# ---------------------------------------------------------------------------
# DNS hostnames. All three must resolve to this VPS's public IP (A/AAAA).
#
#   DOMAIN_RDV  -- bare hostname clients connect to for hbbs/hbbr (TCP/UDP).
#                  This is ALSO embedded in every client build via GitHub
#                  Secrets (RENDEZVOUS_SERVER, RELAY_SERVER). Rename requires
#                  rebuild of every client.
#   DOMAIN_API  -- https:// hostname for the admin UI, web client, and API.
#   DOMAIN_DL   -- https:// hostname for the installer download portal.
# ---------------------------------------------------------------------------
DOMAIN_RDV=rdv.example.com
DOMAIN_API=api.example.com
DOMAIN_DL=dl.example.com

# ---------------------------------------------------------------------------
# Email used for Let's Encrypt ACME registration (receives expiry warnings).
# ---------------------------------------------------------------------------
ACME_EMAIL=admin@example.com

# ---------------------------------------------------------------------------
# Server policy.
#
#   MUST_LOGIN=Y
#     Clients must authenticate against the API before connecting. Strongly
#     recommended for a managed fleet. Set to N only if you deliberately
#     allow anyone holding the public key to initiate a session.
# ---------------------------------------------------------------------------
MUST_LOGIN=Y

# ---------------------------------------------------------------------------
# JWT signing key used by rustdesk-api.
# Generate with:   openssl rand -hex 32
# Rotating invalidates all active admin/device sessions.
# ---------------------------------------------------------------------------
RUSTDESK_API_JWT_KEY=<CHANGE_ME_openssl_rand_hex_32>

# ---------------------------------------------------------------------------
# admin-pw-service HMAC key.
#
# Shared secret between the branded client binary (baked in at build time
# via the BRAND_ADMIN_PW_HMAC_KEY GitHub Secret — same value) and the
# admin-pw sidecar that stores each device's auto-generated peer
# password. Rotating this requires a client rebuild + redeploy.
#
# Generate with:  openssl rand -base64 32
# ---------------------------------------------------------------------------
BRAND_ADMIN_PW_HMAC_KEY=<CHANGE_ME_openssl_rand_base64_32>
# Optional: previous key, accepted during rotation windows so in-flight
# clients don't break while they are being rebuilt.
# BRAND_ADMIN_PW_HMAC_KEY_PREV=

# ---------------------------------------------------------------------------
# Admin UI language (en, zh-CN, …).
# ---------------------------------------------------------------------------
RUSTDESK_API_LANG=en
