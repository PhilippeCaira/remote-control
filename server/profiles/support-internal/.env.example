# ============================================================================
# remote-control — profile `support-internal`
#
# Standalone .env for the 2-VM end-to-end test profile (Debian server VM +
# Windows client VM on the same bridged LAN, hostnames resolved via /etc/hosts
# on each side, TLS issued by Caddy's built-in local CA).
#
# Usage on the server VM:
#   cd server/
#   cp profiles/support-internal/.env.example .env
#   chmod 600 .env
#   # edit RUSTDESK_API_JWT_KEY below
#   export COMPOSE_FILE=docker-compose.yml:profiles/support-internal/override.yml
# ============================================================================

TZ=Europe/Brussels

# Hostnames resolved via /etc/hosts on server VM and C:\Windows\...\hosts on
# Windows client VM — no public DNS required. Must match what is baked into
# the client at build time (see client/.env GitHub Secrets).
DOMAIN_RDV=rdv.support.internal
DOMAIN_API=api.support.internal
DOMAIN_DL=dl.support.internal

# Unused by `tls internal`, but the Caddyfile global block references it — any
# syntactically valid address is fine.
ACME_EMAIL=dev@support.internal

# Start with N so the first admin can be created and clients can register.
# Flip to Y after users exist, then `docker compose up -d` to re-apply.
MUST_LOGIN=N

# MUST be rotated from the placeholder. Generate with: openssl rand -hex 32
RUSTDESK_API_JWT_KEY=<CHANGE_ME_openssl_rand_hex_32>

RUSTDESK_API_LANG=en

# ----------------------------------------------------------------------------
# Download proxy targets (dl.support.internal 302s → GitHub Releases).
# The Caddyfile composes URLs like
#   https://github.com/$GITHUB_REPO_SLUG/releases/latest/download/$BRAND_APP_NAME-x86_64.msi
# so these two values must match the upstream repo + the client-side
# $BRAND_APP_NAME used at build time.
# ----------------------------------------------------------------------------
GITHUB_REPO_SLUG=PhilippeCaira/remote-control
BRAND_APP_NAME=SupportInternal
