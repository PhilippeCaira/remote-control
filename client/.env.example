# ============================================================================
# Client build — environment contract.
#
# Every variable below is MANDATORY. apply-branding.sh refuses to run if
# any is missing (it uses `${VAR:?}` guards). In CI they come from GitHub
# Actions secrets; locally, copy this file to `.env` and:
#
#   set -a
#   source client/.env
#   set +a
#   client/scripts/apply-branding.sh
#
# `.env` is gitignored. Never commit the real values — they are the
# cryptographic identity of your server fleet.
# ============================================================================

# ---------------------------------------------------------------------------
# Server endpoints (must match the server actually running on your VPS).
#
#   RENDEZVOUS_SERVER -- bare hostname of hbbs (no port, no scheme)
#   RS_PUB_KEY        -- hbbs ed25519 public key, single line, base64
#                        obtain via `server/scripts/init-keys.sh`
#   API_SERVER        -- full https:// URL of the rustdesk-api admin service
# ---------------------------------------------------------------------------
RENDEZVOUS_SERVER=rdv.example.com
RS_PUB_KEY=<paste-single-line-base64-pubkey-here>
API_SERVER=https://api.example.com

# ---------------------------------------------------------------------------
# Product identity.
#
#   BRAND_APP_NAME        -- what end users see in window titles, logs,
#                            notifications. Alphanumeric, no spaces.
#                            Example: RemoteControl
#   BRAND_ORG             -- reverse-DNS organisation prefix, used as
#                            config/log directory root. Lowercase.
#                            Example: com.example
#   BRAND_ANDROID_APP_ID  -- Android applicationId. Must be globally
#                            unique on Play (or your own distribution).
#                            Example: com.example.remotecontrol
#   BRAND_MACOS_BUNDLE_ID -- macOS bundle identifier. Can match the
#                            Android one or differ if you hold separate
#                            signing identities.
#                            Example: com.example.remotecontrol
#   BRAND_COPYRIGHT       -- displayed in "About" and in macOS app info.
#                            Example: "Copyright (c) 2026 Example SA"
#
# The *crate* name (`rustdesk`) and the Flutter package name
# (`flutter_hbb`) are NOT changed: those are internal identifiers used
# by `use` / `import` statements throughout the code. Only user-visible
# strings are rewritten.
# ---------------------------------------------------------------------------
BRAND_APP_NAME=RemoteControl
BRAND_ORG=com.example
BRAND_ANDROID_APP_ID=com.example.remotecontrol
BRAND_MACOS_BUNDLE_ID=com.example.remotecontrol
BRAND_COPYRIGHT="Copyright (c) 2026 Example SA"

# ---------------------------------------------------------------------------
# Auto-update endpoint.
#
# The installed client POSTs here once every 24h and expects a JSON body
#   {"url":"https://github.com/<owner>/<repo>/releases/tag/vX.Y.Z"}
# Upstream default is https://api.rustdesk.com/version/latest — we point
# it at a static JSON hosted on the project's GitHub Pages, refreshed by
# the release workflow. Nothing fancy: a file server is enough because
# version-check requests are POSTs whose body is ignored by Pages.
#
# The download URL is derived by the client:
#   <tag_url>.replace("tag","download")/${BRAND_APP_NAME}-<version>-x86_64.msi
# apply-branding.sh patches that filename pattern in updater.rs.
# ---------------------------------------------------------------------------
UPDATE_CHECK_URL=https://example.github.io/repo/version/latest.json

# ---------------------------------------------------------------------------
# Fleet registration account.
#
# Baked into the client binary. At first boot of the Windows service the
# client POSTs /api/login with these credentials, then upserts itself
# into the admin's address book via /api/ab so the admin UI's ljw.js can
# auto-fill the peer password into the web client's localStorage —
# clicking "Web Client" on a peer connects without any password prompt.
#
# The default install of rustdesk-api creates a single admin account
# (password printed in the container logs at first boot); use that for
# MVP. For production, create a dedicated low-privilege account via the
# admin UI and point these at it.
# ---------------------------------------------------------------------------
BRAND_FLEET_USER=admin
BRAND_FLEET_PASSWORD=<paste-admin-password-from-rustdesk-container-logs>
